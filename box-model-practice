*{
    margin: o;
    padding: 0;
    box-sizing: border-box;
}

body{
    font-family: Arial,sans-serif;
    padding: 20px;
}

.container{
    display: flex;
    gap: 20px;
    margin-bottom: 40px;

}

.box{
    width: 300px;
    padding: 20px;
    border: 5px solid black;
    margin: 10px;
    background-color: lightblue;
}

.content-box{
    background-color: lightgreen;
}

.padding-box{
    background-color: lightcoral;
}

.border-box{
    background-color: lightyellow;
    border: 5px dashed red;
}

.margin-box{
    background-color: lightgray;
    margin: 30px;
}

.card{
    width: 300px;
    border: 1px solid gray;
    padding: 20px;
    border-radius: 8px;
    background: #fff;
}

.card img{
    width: 100%;
    display: block;
    margin-bottom: 15px;
}

.card h3{
    margin-bottom: 15px;
}

.card p{
    margin-bottom:n 20px;
}

.card button{ 
    width: 100%;
    padding: 10px;
    border: none;
    background: black;
    color: white;
    cursor: pointer;
}

.card button:hover{
    background: #333;
}


